# ── HervBot Environment Variables ──
# Copy file ini menjadi .env dan isi nilainya

# Telegram Bot Token (dari @BotFather di Telegram)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Groq API Key GRATIS (dari console.groq.com)
GROQ_API_KEY=gsk_your_groq_key_here

# Wallet Private Key (JAGA KERAHASIAANNYA!)
# Gunakan wallet khusus trading, bukan wallet utama!
WALLET_PRIVATE_KEY=your_wallet_private_key_here

# Port server (Railway otomatis set ini)
PORT=3000
